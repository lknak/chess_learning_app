<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ChessApp;assembly=ChessApp"
             x:Class="ChessApp.MainPage"
             NavigationPage.HasNavigationBar="False">

    <StackLayout BackgroundColor="#777777">
        <Frame BackgroundColor="#000000" Padding="24" CornerRadius="0">
            <Label Text="Chess App" HorizontalTextAlignment="Center" TextColor="White" FontSize="36"/>
        </Frame>
        <Label Text="What do you want to do?" HorizontalTextAlignment="Center" TextColor="#DDDDDD" FontSize="Title" Padding="30,10,30,10"/>
        <StackLayout Margin="20" Spacing="10">
            <Button Text="Start game" BackgroundColor="#333333" FontSize="16" TextColor="#EEEEEE" Padding="10" CornerRadius="10" Clicked="start_clicked" />
            <Button Text="Learn" BackgroundColor="#333333" FontSize="16" TextColor="#EEEEEE" Padding="10" CornerRadius="10" Clicked="learn_clicked"/>
            <Button Text="Exit" BackgroundColor="#333333" FontSize="16" TextColor="#EEEEEE" Padding="10" CornerRadius="10" Clicked="exit_clicked"/>
        </StackLayout>

    </StackLayout>

</ContentPage>
